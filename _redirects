# Homepage redirects to the web app
/   /cards/   302

# Rewrite node_modules asset paths to modules (Cloudflare Pages skips node_modules)
/cards/assets/node_modules/*  /cards/assets/modules/:splat  200

# Legal pages — serve static HTML directly
/cards/privacy-policy   /cards/privacy-policy.html   200
/cards/terms-of-service /cards/terms-of-service.html  200

# SPA fallback — serve index.html for all /cards/ routes
/cards/*  /cards/index.html  200

